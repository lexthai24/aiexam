// Prisma schema for the AI-powered online exam system.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A single exam question. `key` is a stable, human-readable identifier
/// (e.g. "q1") used by the seed script to stay idempotent.
model Question {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  number    Int // display order within the exam
  category  String // หมวด / section name
  text      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  choices     Choice[]
  explanation Explanation?
  attempts    Attempt[]

  @@index([number])
  @@index([category])
}

/// One answer option belonging to a question.
model Choice {
  id         Int     @id @default(autoincrement())
  questionId Int
  label      String // ก / ข / ค / ง
  text       String  @db.Text
  isCorrect  Boolean @default(false)
  order      Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, label])
  @@index([questionId])
}

/// Cached AI explanation for a question. Because the correct answer for a
/// question never changes, we cache exactly one explanation per question so
/// repeated views never spend Deepseek quota again.
model Explanation {
  id         Int      @id @default(autoincrement())
  questionId Int      @unique
  content    String   @db.Text
  model      String // which model produced it (e.g. deepseek-chat)
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

/// A lightweight user identified by a display name + 4-digit PIN. This is not
/// full authentication (no email, no password) — it exists so that data
/// separates per person and follows them across devices/shared computers, which
/// an anonymous per-browser id cannot do. The PIN is stored only as a hash.
model User {
  id        Int       @id @default(autoincrement())
  name      String
  pinHash   String
  createdAt DateTime  @default(now())
  attempts  Attempt[]

  // A given display name may be reused by different people, distinguished by PIN.
  @@unique([name, pinHash])
  @@index([name])
}

/// A record of a user answering a question. Linked to a User so progress and
/// mistake-review are per person.
model Attempt {
  id          Int      @id @default(autoincrement())
  userId      Int
  questionId  Int
  chosenLabel String
  isCorrect   Boolean
  createdAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionId])
}
